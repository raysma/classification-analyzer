{
  "name": "classification-analyzer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev",
    "build": "tsc --noEmit && vite build",
